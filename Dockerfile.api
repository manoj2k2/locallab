# Dockerfile for the API Input Adapter
FROM python:3.10-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PYTHONPATH=/

CMD ["python", "-m", "uvicorn", "src.input_adapters.api_adapter:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
